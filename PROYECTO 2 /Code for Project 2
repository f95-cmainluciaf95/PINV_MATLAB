% Ainv = inv(A); %  Exercise 2: Using A^-1 for solving the inverse problem
d = D*deltat/((deltax)^2);
diag = sparse(1:M,1:M,(1+2*d)*ones(1,M),M,M);
ud = sparse(1:M-1,2:M,-d,M,M);
ld = sparse(2:M,1:M-1,-d,M,M);
Ainv = diag + ud + ld;
uT = u(:,end);
u2 = [zeros(M,N+1), uT];
T0 = T-10*deltat;
for j = N+2:-1:N+2-10
    u2(:,j-1) = Ainv*u2(:,j);
end 
u2 = [zeros(1,N+2); u2;zeros(1,N+2)];
figure
plot(x,u2(:,N+1-10))
hold on 
plot(x,uexact(x(1:M+2),T0))
hold off

% Datos con ruido / Noisy data
eps = 0.0001;
uT_ruido = uT +eps.*(2*rand(size(uT))-1*ones(size(uT)));
u2_ruido = [zeros(M,N+1), uT_ruido];

for j = N+1:-1:N+1-10
    u2_ruido(:,j) = Ainv*u2_ruido(:,j+1);
end 
u2_ruido = [zeros(1,N+2); u2_ruido;zeros(1,N+2)];

figure
plot(x,u2_ruido(:,N+1-10))
hold on 
plot(x,uexact(x(1:M+2),T0))
hold off
legend('Solucion aproximada con ruido','Solucion exacta')


