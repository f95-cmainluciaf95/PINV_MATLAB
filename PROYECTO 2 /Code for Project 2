% PROYECTO 2 / PROJECT 2 : In this project we will see the importance of using different meshes to create and reconstruct simulated data

% Ejercicio 1 / Exercise 1 : solve the well-posed problem using the finite difference method and compare the numerical solution
% with the exact solution
L = pi;
T = 1;
D = 1;
M = 40;
N = 250;
deltax = L/(M+1);
x = linspace(0,L,M+1+1);
f = @(x) 10*sin(2*x);
deltat = T/(N+1);

d = D*deltat/((deltax)^2);
diag = sparse(1:M,1:M,(1-2*d)*ones(1,M),M,M);
ud = sparse(1:M-1,2:M,d,M,M);
ld = sparse(2:M,1:M-1,d,M,M);
A = diag + ud + ld;
u = zeros(M,N+2);
u(:,1) = f(x(2:M+1));

for j = 2:N+2
    u(:,j) = A*u(:,j-1);
end


uexact =  @(x,t) 10*exp(-4*t)*sin(2*x);
uex = uexact(x(2:M+1),T);

maxrel = max(abs(uex-u(:,N+2)'))/max(abs(uex));

fprintf('M es :%.4f\n ', M)
fprintf('N es :%.4f\n ', N)
fprintf('deltax es :%.4f\n ', deltax)
fprintf('delta t es :%.4f\n ', deltat)
fprintf('d es:%.4f\n',d)
fprintf('Error relativo en T=0.1 es :%.16f\n ', maxrel)


