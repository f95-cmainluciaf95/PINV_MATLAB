% Descomposicion en valores singulares / Singular value decomposition
[U,S,V] = svd(Akn,"econ");

d = diag(S);

av = 1/d(1)*d;
plot(log(av),'x','LineWidth',1.5)

av_masgrandes = av(av>1.e-16);
num = numel(av_masgrandes);
r = rank(Akn);

for k = 1:r
    % TSVD
    Uk = U(:, 1:k);
    Sk = S(1:k, 1:k);
    diagonal_truncada = diag(Sk);
    Vk = V(:, 1:k);
    S_pseudoinversa = sparse(1:k,1:k,1./diag(Sk),k,k);
    solucion_SVD = Vk*S_pseudoinversa*Uk'*datosInterp';
    
    % WSVD / Weighted SVD
    % Construimos una versión suavizada de la pseudoinversa / We construct a smoothed version of the pseudoinverse
    % Se mantienen los k primeros valores exactos y suavizamos los restantes / The first k values ​​are kept exact and the remaining values ​​are smoothed.
    S_WSVD_inv = zeros(r,r);
    for i = 1:r
        if i <= k
            S_WSVD_inv(i,i) = 1/d(i); % primeros k valores exactos / first k exact values
        else
            S_WSVD_inv(i,i) = 1/d(k); % valores pequeños suavizados / small smoothed values
        end
    end

    solucion_WSVD = V(:,1:r)*S_WSVD_inv*U(:,1:r)'*datosInterp';
   
    figure
    plot(xk,fexact(xk),'LineWidth',1.5)
    hold on
    plot(xk,solucion_SVD,'LineWidth',1.5)
    plot(xk,solucion_WSVD,'LineWidth',1.5)
    grid on
    hold off
    legend('Solución exacta', 'Solución con TSVD', 'Solución con WSVD')
    title(['Reconstrucción usando SVD truncada y SVD con pesos con k =',num2str(k)])
    clear solucion_SVD
end

