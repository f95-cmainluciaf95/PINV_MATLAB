% Resolver Akn*F = datosInterp por el metodo de tikhonov con aprox inicial
% nula y seleccionando en alpha adecuado /
% Solve Akn*F = datosInterp by the tikhonov method with zero initial 
% approximation and selecting at appropriate alpha

eps = 0.01;
% datosInterp = datosInterp + eps*max(datosInterp)*(2*rand(size(datosInterp))...
   -1*ones(size(datosInterp)));  % Descomentar para introducir pertubacion aleatoria a los datos / Uncomment to introduce random disturbance to the data

% Método de Tikhonov seleccionando alpha con el principio de discrepancia de mozorov / 
% Tikhonov's method selecting alpha with the Mozorov discrepancy principle
alpha = 0.001:0.001:1;
alpha_optimo = 0.0001;
for k = 1:length(alpha)
    ATik = Akn'*Akn+alpha(k)*eye(size(Akn));
    bTik = Akn'*datosInterp';
    sol = ATik\bTik;
    difk = norm(Akn*sol-datosInterp');
    
    if eps*norm(datosInterp)<difk && difk < 1.2*eps*norm(datosInterp) && alpha(k) > alpha_optimo  % Principio de discrepancia de Mozorov / Morozov's discrepancy principle
        alpha_optimo = alpha(k);
        sol_alpha_optimo = sol;
        condi = cond(ATik);
    end      
end

